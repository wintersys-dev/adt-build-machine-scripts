#Pick one build style for each component you want to enable installation for. The choice of which to install e.g. NGINX or APACHE is made elsewhere
#All this does is tell us how to build it not whether to build it
#-----------------------------------------------------NGINX---------------------------------------------------------------------------------
#Install NGINX using the cloud-init default
#NGINX:cloud-init
#NGINX:modules-list:mpm_event:ssl:rewrite:expires:headers:proxyproxy_http:remoteip:proxy_fcgi
#NGINX:settings:client_body_timeout=15:client_header_timeout=20:keepalive_timeout=10:keepalive_requests=100:reset_timedout_connection=on

#Install NGINX from a repository
# One of repo:os or repo:official 
NGINX:repo:os
#NGINX:repo:official
#leave mainline commented to install the stable version when configured for official repos uncomment mainline to install mainline version
#NGINX:mainline
NGINX:modules-list:mpm_event:ssl:rewrite:expires:headers:proxyproxy_http:remoteip:proxy_fcgi
NGINX:settings:client_body_timeout=15:client_header_timeout=20:keepalive_timeout=10:keepalive_requests=100:reset_timedout_connection=on

#Install NGINX from source based on the f5 version (you can do it from github or from the f5 archives (comment in one and comment out the other))
#NGINX:source
#NGINX:fork:f5
# One of git-branch or sourcecode_url (git takes precedence if both are present)
#NGINX:git-branch:release-1.29.0
#NGINX:sourcecode_url:nginx.org/download/nginx-1.29.0.tar.gz
#NGINX:static-modules-list:select:poll:http_v2:http_ssl:http_v2:http_realip:http_addition:http_sub:http_dav:http_flv:http_mp4:http_gunzip:http_gzip_static:http_auth_request:http_random_index:http_secure_link:http_degradation:http_slice:http_stub_status:stream_ssl_preread:mail_ssl:stream_ssl:stream_realip:http_realip
#NGINX:settings:client_body_timeout=15:client_header_timeout=20:keepalive_timeout=10:keepalive_requests=100:reset_timedout_connection=on
#NGINX:software-packages:build-essential:libpcre2-dev:libssl-dev:zlib1g-dev:libgd-dev:gnupg2

#Install NGINX from source based on freenginx version (you can do it from github or from the freenginx archives (comment in one and comment out the other))
#NGINX:source
#NGINX:fork:free
# One of git-branch or sourcecode_url (git takes precedence if both are present)
#NGINX:git-branch:release-1.29.0
#NGINX:sourcecode_url:freenginx.org/download/freenginx-1.29.0.tar.gz 
#NGINX:static-modules-list:select:poll:http_v2:http_ssl:http_v2:http_realip:http_addition:http_sub:http_dav:http_flv:http_mp4:http_gunzip:http_gzip_static:http_auth_request:http_random_index:http_secure_link:http_degradation:http_slice:http_stub_status:stream_ssl_preread:mail_ssl:stream_ssl:stream_realip:http_realip
#NGINX:settings:client_body_timeout=15:client_header_timeout=20:keepalive_timeout=10:keepalive_requests=100:reset_timedout_connection=on
#NGINX:software-packages:build-essential:libpcre2-dev:libssl-dev:zlib1g-dev:libgd-dev:gnupg2

#----------------------------------------------------APACHE----------------------------------------------------------------------------------
#Install APACHE using the cloud init default
#APACHE:cloud-init
#APACHE:modules-list:mpm_event:ssl:rewrite:expires:headers:proxy:proxy_http:remoteip:proxy_fcgi
#APACHE:settings:StartServers=4:MinSpareServers=20:MaxSpareServers=40:MaxRequestWorkers=200:MaxConnectionsPerChild=4500

#Install APACHE from repositories
APACHE:repo
APACHE:modules-list:mpm_event:ssl:rewrite:expires:headers:proxy:proxy_http:remoteip:proxy_fcgi
APACHE:settings:StartServers=4:MinSpareServers=20:MaxSpareServers=40:MaxRequestWorkers=200:MaxConnectionsPerChild=4500

#Install APACHE from source (you can do it from github or from the apache archives (comment in one and comment out the other))
#APACHE:source
#APACHE:git-branch:2.4.66
#APACHE:apr:git-branch:1.7.6
#APACHE:apr-util:git-branch:1.6.3
#APACHE:sourcecode_url:downloads.apache.org/httpd/httpd-2.4.66.tar.gz
#APACHE:sha256_url:downloads.apache.org/httpd/httpd-2.4.66.tar.gz.sha256
#APACHE:sha512_url:downloads.apache.org/httpd/httpd-2.4.66.tar.gz.sha512
#APACHE:apr_sourcecode_url:dlcdn.apache.org//apr/apr-1.7.6.tar.gz
#APACHE:apr_sha256_url:www.apache.org/dist/apr/apr-1.7.6.tar.gz.sha256
#APACHE:apr_util_sourcecode_url:dlcdn.apache.org//apr/apr-util-1.6.3.tar.gz
#APACHE:apr_util_sha256_url:www.apache.org/dist/apr/apr-util-1.6.3.tar.gz.sha256
#APACHE:modules-list:ssl:rewrite:alias:expires:headers:proxy:proxy_http:remoteip:proxy_fcgi:socache_shmcb:log_config:log_debug:logio:dir:unixd:authn_core:authn_file:authz_user:authz_core:http2:slotmem_shm:cache:deflate:mime:filter
#APACHE:static-modules-list:mpm_event
#APACHE:settings:StartServers=4:MinSpareServers=20:MaxSpareServers=40:MaxRequestWorkers=200:MaxConnectionsPerChild=4500
#APACHE:software-packages:libtool-bin:autoconf:libpcre2-dev:build-essential:zlib1g-dev:libssl-dev:libnghttp2-dev:libexpat1-dev


#----------------------------------------------------LIGHTTPD----------------------------------------------------------------------------------
#Install lighttpd from cloud-init defaults
#LIGHTTPD:cloud-init
#LIGHTTPD:modules-list:mod_indexfile:mod_access:mod_accesslog:mod_alias:mod_auth:mod_deflate:mod_openssl:mod_dirlisting:mod_proxy:mod_fastcgi:mod_staticfile:mod_expire:mod_userdir:mod_status:mod_setenv::mod_redirect:mod_rewrite:mod_authn_file
#LIGHTTPD:settings:server.use-ipv6="disable":server.bind="localhost":server.max-fds=2048:server.stat-cache-engine="simple"

#Install lighttpd from repos
#LIGHTTPD:repo
#LIGHTTPD:modules-list:mod_indexfile:mod_access:mod_accesslog:mod_alias:mod_auth:mod_deflate:mod_openssl:mod_dirlisting:mod_proxy:mod_fastcgi:mod_staticfile:mod_expire:mod_userdir:mod_status:mod_setenv::mod_redirect:mod_rewrite:mod_authn_file
#LIGHTTPD:settings:server.use-ipv6="disable":server.max-fds=2048:server.stat-cache-engine="simple"

#Install LIGHTTPD from source (you can do it from github or from the lighttpd archives (comment in one and comment out the other))
LIGHTTPD:source
#LIGHTTPD:git-branch:lighttpd-1.4.82
LIGHTTPD:sourcecode_url:download.lighttpd.net/lighttpd/releases-1.4.x/lighttpd-1.4.82.tar.gz
LIGHTTPD:sha256_url:download.lighttpd.net/lighttpd/releases-1.4.x/lighttpd-1.4.82.sha256sum
LIGHTTPD:sha512_url:download.lighttpd.net/lighttpd/releases-1.4.x/lighttpd-1.4.82.sha512sum
LIGHTTPD:modules-list:mod_indexfile:mod_access:mod_accesslog:mod_alias:mod_auth:mod_deflate:mod_openssl:mod_dirlisting:mod_proxy:mod_fastcgi:mod_staticfile:mod_expire:mod_userdir:mod_status:mod_setenv::mod_redirect:mod_rewrite:mod_authn_file
LIGHTTPD:static-modules-list:zlib:libxml:openssl:gnutls
LIGHTTPD:settings:server.use-ipv6="disable":server.max-fds=2048:server.stat-cache-engine="simple"
LIGHTTPD:software-packages:autoconf:build-essential:automake:libtool:pkg-config:libssl-dev:libgnutls28-dev:libpcre2-dev:zlib1g-dev

#----------------------------------------------------PHP---------------------------------------------------------------------------------
###Set what base PHP libraries you want installed. Install application specific libraries in your application descriptor####
PHP:cli:fpm|9176  
#---------------------------------------------DATASTORE MOUNT TOOL----------------------------------------------------------------------
#DATASTOREMOUNTTOOL:rclone:binary
#DATASTOREMOUNTTOOL:s3fs:source
#DATASTOREMOUNTTOOL:goof:binary
#DATASTOREMOUNTTOOL:geesefs:source
#---------------------------------------------DATASTORE CONFIG TOOL OPERATION STYLE-------------------------------------------------------
DATASTORECONFIGSTYLE:tool
#DATASTORECONFIGSTYLE:lightweight
#DATASTORECONFIGSTYLE:heavyweight
#---------------------------------------------DATABASES----------------------------------------------------------------------------------
#MARIADB:cloud-init
MARIADB:repo:12.2.2
MYSQL:repo:9.2.0
POSTGRES:repo:17
#---------------------------------------------BUILD CHAIN------------------------------------------------------------------------------
BUILDCHAINTYPE:standard
#---------------------------------------------DATASTORE TOOL----------------------------------------------------------------------------------
#DATASTORETOOL:s3cmd:source 
#DATASTORETOOL:s5cmd:source
DATASTORETOOL:rclone:binary
#---------------------------------------------CLOUD CLI TOOL----------------------------------------------------------------------------------
#CLOUDCLITOOL:doctl:binary
CLOUDCLITOOL:doctl:snap
CLOUDCLITOOL:linode-cli:pip
#CLOUDCLITOOL:linode-cli:snap
#CLOUDCLITOOL:exo:repo
CLOUDCLITOOL:exo:source
#CLOUDCLITOOL:vultr:binary
CLOUDCLITOOL:vultr:source
#---------------------------------------------GO----------------------------------------------------------------------------------
#GO:repo
GO:binary
#---------------------------------------------MERGER FS----------------------------------------------------------------------------
MERGEFILESYSTEMSTOOL:mergefs:repo
#---------------------------------------------PACKAGE MANAGER----------------------------------------------------------------------
PACKAGEMANAGER:apt-get
#---------------------------------------------FIREWALL-----------------------------------------------------------------------------
FIREWALL:ufw
#FIREWALL:iptables:20:30
#---------------------------------------------FAIL 2 BAN-----------------------------------------------------------------------------
FAIL2BAN:active
#---------------------------------------------EMAIL---------------------------------------------------------------------------------
EMAILUTIL:sendemail
#---------------------------------------------SSL CERT CLIENT-----------------------------------------------------------------------
#SSLCERTCLIENT:acme:github.com
SSLCERTCLIENT:lego:snap
#---------------------------------------------GIT BRANCH OF INFRASTRUCTURE REPOS-----------------------------------------------------
GITBRANCH:main
#---------------------------------------------VIRUS SCANNER------------------------------------------------------------------------
VIRUSSCANNER:clamav:daily
