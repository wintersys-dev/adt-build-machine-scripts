##########################################################################################################################################
# This is an application descriptor for Open Source Social Network. 
# https://github.com/Iqbolshoh/php-social-messenger
# Using this technique you can automate the installation of social messenger
# Using descriptors we can aim for consistent installation processes which takes some of the potential for error out of the 
# installation process.
##########################################################################################################################################

##########################################################################################################################################
# social messenger is available on github
##########################################################################################################################################
#To install from a git branch, use this
SOCIAL-MESSENGER:git-branch:main

######################################################################################################################################################
#This sets the webroot of your application. You can change this according to your taste. 
######################################################################################################################################################
WEBROOT_DIRECTORY:/var/www/html/social-messenger


#####################################################################################################################################################
# Mandatory credential settings when making a non-interactive installation
# These are mandatory database settings that are absolutely required for there to be any chance of your application coming online if you are installing
# social messenger non-interactively. Notice that placeholders are used and are populated privately with live data in the script
# ${BUILD_HOME}/application/social-messenger/SetApplicationConfig.sh
#####################################################################################################################################################
MANDATORY_INDIVIDUAL_SETTING:user='XXXXAPPLICATION_USERNAMEXXXX'
MANDATORY_INDIVIDUAL_SETTING:password='XXXXAPPLICATION_PASSWORDXXXX'
MANDATORY_INDIVIDUAL_SETTING:db='XXXXAPPLICATION_DATABASEXXXX'

